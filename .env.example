# LogicLab — Environment Variables
# Copy this file to .env and fill in your credentials.

# ── Supabase (required for auth, leaderboards, sync) ──────────────────────────
# Find these at: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase Service Role Key (server-side only, never expose to browser) ──────
# Used by Vercel API routes (api/generate-daily.ts) to bypass RLS when writing
# Find at: https://supabase.com/dashboard/project/_/settings/api → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic Claude API (server-side only, never expose to browser) ───────────
# Used by api/generate-daily.ts to generate daily challenge questions
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
